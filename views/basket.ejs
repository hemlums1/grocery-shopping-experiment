<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Basket</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,450;9..144,560&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <header class="topbar">
    <h1>Your Basket</h1>
    <div class="topbar-right">
      <div class="budget" data-over="<%= total > budget %>">
        Budget $<%= (budget / 100).toFixed(2) %> &middot;
        Spent $<%= (total / 100).toFixed(2) %> &middot;
        Remaining $<%= ((budget - total) / 100).toFixed(2) %>
      </div>
      <a href="/" class="basket-link">&larr; Continue Shopping</a>
    </div>
  </header>

  <main class="basket-page">
    <% if (items.length === 0) { %>
      <p class="empty-basket">Your basket is empty. <a href="/">Browse the shop</a> to add something.</p>
    <% } else { %>
      <div class="basket-list" id="basket-list">
        <% items.forEach(function (item) { %>
          <article class="basket-row" data-item-id="<%= item.id %>">
            <div class="item-image basket-image">
              <button type="button" class="zoom-trigger">
                <img src="<%= item.image %>" alt="<%= item.productType %>" loading="lazy">
              </button>
            </div>
            <div class="basket-row-info">
              <p class="item-brand"><%= item.brand %></p>
              <h3><%= item.name %></h3>
              <div class="item-meta">
                <span class="nutri-badge" style="background:<%= nutriColors[item.nutriScore] %>"><%= item.nutriScore %></span>
                <span class="sourcing"><%= item.sourcingPractice %> &middot; <%= item.country %></span>
              </div>
            </div>
            <div class="basket-row-controls">
              <form method="POST" action="/basket/update" class="qty-form" data-price-cents="<%= item.priceCents %>">
                <input type="hidden" name="itemId" value="<%= item.id %>">
                <input type="hidden" name="returnTo" value="basket">
                <button name="qtyAction" value="decrement">&minus;</button>
                <span class="qty"><%= item.quantity %></span>
                <button name="qtyAction" value="increment" <%= (total + item.priceCents > budget) ? 'disabled' : '' %>>+</button>
              </form>
              <p class="price"><%= item.quantity %> &times; $<%= (item.priceCents / 100).toFixed(2) %> = $<%= ((item.priceCents * item.quantity) / 100).toFixed(2) %></p>
            </div>
          </article>
        <% }); %>
      </div>
    <% } %>

    <p class="total">Total: $<%= (total / 100).toFixed(2) %> of $<%= (budget / 100).toFixed(2) %> budget</p>
  </main>

  <footer>
    <a href="/review" class="btn">Finish Shopping</a>
  </footer>

  <%- include('partials/lightbox') %>
  <script src="/public/js/basket.js" defer></script>
</body>
</html>
